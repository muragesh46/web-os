{
  "name": "muragesh-mac",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "format": "prettier --write 'src/**/*.{js,jsx,css}'",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env ELECTRON_START_URL=http://localhost:5173 electron .\"",
    "electron:build": "vite build && electron-builder",
    "prepare": "husky install"
  },
  "build": {
    "appId": "com.murageshos.app",
    "productName": "Muragesh Mac",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@tailwindcss/vite": "^4.1.17",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/ui": "^4.1.8",
    "axios": "^1.13.5",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dayjs": "^1.11.19",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "gsap": "^3.13.0",
    "happy-dom": "^20.10.1",
    "husky": "^9.1.2",
    "immer": "^10.2.0",
    "jsdom": "^29.1.1",
    "leaflet": "^1.9.4",
    "lint-staged": "^15.2.2",
    "lucide-react": "^0.554.0",
    "prettier": "^3.1.1",
    "react": "^19.2.0",
    "react-calendar": "^6.0.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.2.0",
    "react-tooltip": "^5.30.0",
    "remark-gfm": "^4.0.1",
    "socket.io-client": "^4.8.3",
    "tailwindcss-animate": "^1.0.7",
    "vite": "^7.2.4",
    "vitest": "^4.1.8",
    "wait-on": "^9.0.5",
    "zustand": "^5.0.13"
  }
}
